# ============================================
# Multimodal RAG System - Environment Configuration
# ============================================
# 複製此檔案為 config.env 並填入您的值
# cp config.env.example config.env

# --------------------------------------------
# Google Gemini API (必要)
# 取得: https://aistudio.google.com/app/apikey
# --------------------------------------------
GOOGLE_API_KEY=your-google-api-key-here

# --------------------------------------------
# Supabase (生產環境必要)
# 取得: https://supabase.com/dashboard
# --------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-public-key-here

# --------------------------------------------
# HuggingFace (選用 - 某些模型需要)
# 取得: https://huggingface.co/settings/tokens
# --------------------------------------------
HF_TOKEN=your-huggingface-token-here

# --------------------------------------------
# 認證測試說明
# 請使用 pytest dependency_overrides 進行測試身分注入
# （不提供 runtime 環境變數繞過認證）
# --------------------------------------------

# --------------------------------------------
# CORS（本機 preview / docker 前端可依需要覆寫）
# 例：
# CORS_ORIGINS=http://localhost:4173,http://127.0.0.1:4173,http://localhost:5173,http://127.0.0.1:5173,http://localhost,http://127.0.0.1
# --------------------------------------------
# CORS_ORIGINS=

# --------------------------------------------
# 測試/模擬模式（避免測試時誤呼叫真實外部 API）
# TEST_MODE=true 時會自動視為使用 fake providers
# --------------------------------------------
TEST_MODE=false
USE_FAKE_PROVIDERS=false

# --------------------------------------------
# CI 封網守門（僅測試）
# 啟用後 pytest 會拒絕非 localhost 連線
# --------------------------------------------
CI_BLOCK_EXTERNAL_NETWORK=false

# --------------------------------------------
# Image OCR 執行裝置策略
# cpu  = 固定 CPU（預設，避免影響 reranker GPU）
# auto = 有可用 CUDA 時使用 GPU，否則回退 CPU
# cuda = 強制嘗試 GPU，失敗時回退 CPU
# --------------------------------------------
IMAGE_OCR_DEVICE=cpu
